# Flat, npm-style node_modules so every dependency (viem, dotenv, …) resolves from
# anywhere in the monorepo. Avoids pnpm's strict-layout "Cannot find package"
# errors when services are launched with `node --import <tsx loader>` under PM2.
node-linker=hoisted

# Don't reject recently-published packages. Some VPS pnpm setups enforce a
# minimum-release-age supply-chain policy that hard-fails installs when a fresh
# transitive dep (e.g. hono) is in the tree. We pin versions via the committed
# lockfile, so age-gating just blocks deploys.
minimum-release-age=0
